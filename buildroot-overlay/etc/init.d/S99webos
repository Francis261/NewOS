#!/bin/sh
# Buildroot init script to boot directly into WebOS

case "$1" in
  start)
    printf 'Starting WebOS... '
    mkdir -p /var/log /opt/webos/data/shared /opt/webos/data/apps
    /usr/bin/xinit /opt/webos/scripts/start-webos.sh -- :0 vt1 &
    echo 'OK'
    ;;
  stop)
    pkill -f chromium-browser || true
    pkill -f 'node server.js' || true
    ;;
  restart)
    "$0" stop
    "$0" start
    ;;
  *)
    echo "Usage: $0 {start|stop|restart}"
    exit 1
    ;;
esac
