{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WebOS Shell",
  "version": "0.1.0",
  "identifier": "com.newos.shell",
  "build": {
    "beforeDevCommand": "npm --prefix frontend run dev",
    "beforeBuildCommand": "npm --prefix frontend run build",
    "frontendDist": "frontend/dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "WebOS",
        "width": 1366,
        "height": 768,
        "fullscreen": true,
        "resizable": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../assets/splash.png"
    ]
  }
}
